# =============================================================================
# DSE Robo-Advisor — Environment Configuration
# Copy this file to .env and fill in production values
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=dse_advisor
POSTGRES_USER=dse_admin
POSTGRES_PASSWORD=          # REQUIRED — use a strong random password
POSTGRES_PORT_BIND=127.0.0.1:5432   # bind to localhost only; remove IP for external access

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=             # REQUIRED — use a strong random password
REDIS_PORT_BIND=127.0.0.1:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                 # REQUIRED — generate with: openssl rand -hex 32

# ── CORS / Allowed Origins ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com

# ── Spring Profiles ──────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── GraphiQL (disable in production) ────────────────────────────────────────
GRAPHIQL_ENABLED=false

# ── Debug mode for analytics engine ─────────────────────────────────────────
DEBUG=false

# ── Nginx ports ──────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Frontend URLs (relative paths work behind nginx) ─────────────────────────
NEXT_PUBLIC_GRAPHQL_URL=/graphql
NEXT_PUBLIC_WS_URL=/ws
