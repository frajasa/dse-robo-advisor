# Copy this file to .env.production and fill in your secrets.
# NEVER commit .env.production to git.

# -- PostgreSQL
POSTGRES_DB=dse_advisor
POSTGRES_USER=dse_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT_BIND=127.0.0.1:5432

# -- Redis
REDIS_PASSWORD=CHANGE_ME

# -- JWT
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_HEX_STRING

# -- CORS / Allowed Origins
ALLOWED_ORIGINS=http://YOUR_SERVER_IP

# -- Spring Profiles
SPRING_PROFILES_ACTIVE=prod

# -- GraphiQL
GRAPHIQL_ENABLED=false

# -- Debug
DEBUG=false

# -- Nginx ports
HTTP_PORT=80
HTTPS_PORT=443

# -- Frontend URLs
NEXT_PUBLIC_GRAPHQL_URL=/graphql
NEXT_PUBLIC_WS_URL=/ws
